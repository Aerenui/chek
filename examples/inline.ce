include "libs/print_int.ce";

int add(a, b)
    return a + b;
end

int main()

    int v1: 1;

    int rs: 0;
    call add(v1, 2) into rs;

    call print_int(v1+2);
    if rs = v1+2 then
        print " == ";
    else
        print " != ";
    end
    call print_int(rs);
    print 10;

    return 0;
end