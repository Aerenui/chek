include "libs/print_int.cm";


int fac(n)
    if n = 1 then
        return 1;
    end
    if n = 0 then
        return 1;
    end
    int val: 0;
    call fac(n-1) into val;
    return n*val;
end


int main()
    int i: 1;
    while i < 11 do
        int result: 0;
        call fac(i) into result;
        call print_int(i);
        print 32;
        call print_int(result);
        print 10;
        set i: i+1;
    end
end