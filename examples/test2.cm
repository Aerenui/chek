# --- Test Utility: Output Formatting ---
# Prints "TEST <id>: " followed by "OK\n" (if 1) or "ERR\n" (if 0)
void report_result(test_id, success_flag)
    # ASCII: T(84) E(69) S(83) T(84) [space](32)
