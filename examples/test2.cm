# ==============================================================================
# MODULE 1: COMPLEX ALGORITHMIC CONTROL FLOW
# ==============================================================================

# Computes Greatest Common Divisor using the Euclidean Algorithm
# Tests: loop condition mutation, nested tracking, modulo evaluation
int compute_gcd(a, b)
    int temp_a: a;
    int temp_b: b;
    while temp_b ! 0 do
        int remainder: temp_a % temp_b;
        set temp_a: temp_b;
        set temp_b: remainder;
    end
    return temp_a;
end

# Simulates the Collatz Conjecture step-counting
# Tests: Intensive interleaved while-loops, modulo execution, and deep branching
int count_collatz_steps(start_num)
    int steps: 0;
    int n: start_num;
    while n ! 1 do
        if n % 2 = 0 then
            set n: n / 2;
        else
            set n: n * 3 + 1;
        end
        set steps: steps + 1;
    end
    return steps;
end


# ==============================================================================
# MODULE 2: HIGH REGISTER PRESSURE & MATRIX SHADOWING
# ==============================================================================

# Deeply Nested Loop Shadowing Matrix
# Tests: Lexical scope tracking across 3 levels of active execution blocks
int execute_scope_stress()
    int target: 50;
    int accumulation: 0;
    int i: 0;

    while i < 3 do
        int target: 100; # Level 1 Shadow
        int j: 0;
        while j < 3 do
            int target: 200; # Level 2 Shadow
            if i = j then
                int target: 1000; # Level 3 Shadow
                set accumulation: accumulation + target;
            else
                set accumulation: accumulation + target;
            end
            set j: j + 1;
        end
        set accumulation: accumulation + target; # Uses 100
        set i: i + 1;
    end

    # Validation Math:
    # i=0 -> j=0(1000), j=1(200), j=2(200) + outer(100) = 1500
    # i=1 -> j=0(200), j=1(1000), j=2(200) + outer(100) = 1500
    # i=2 -> j=0(200), j=1(200), j=2(1000) + outer(100) = 1500
    # Expected accumulation = 4500. Expected root target = 50.
    if target = 50 & accumulation = 4500 then
        return 1;
    end
    return 0;
end

# Sorting Network (Discrete Element Swap)
# Tests: Register allocation efficiency, bulk conditional tracking without arrays
int test_sorting_network(n1, n2, n3, n4)
    int a: n1; int b: n2; int c: n3; int d: n4;
    int swap_space: 0;

    # Sorting network logic for 4 inputs
    if a > b then set swap_space: a; set a: b; set b: swap_space; end
    if c > d then set swap_space: c; set c: d; set d: swap_space; end
    if a > c then set swap_space: a; set a: c; set c: swap_space; end
    if b > d then set swap_space: b; set b: d; set d: swap_space; end
    if b > c then set swap_space: b; set b: c; set c: swap_space; end

    # Validation check: Ensure absolute monotonic order: a <= b <= c <= d
    # Transformed to eliminate unsupported <= operator:
    if (b < a) | (c < b) | (d < c) then
        return 0; # Structural failure
    end
    return 1; # Success
end


