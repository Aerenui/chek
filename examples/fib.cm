int print_int(n)
    int q: n / 10;
    int d: n % 10;
    int c: d + 48;
    if 0 < q then
        call print_int(q) into q;
    end
    print c;
    return 0;
end

void fib(n)
    int a: 0;
    int b: 1;
    int steps: 0;
    while steps < n do
        call print_int(a);
        print 32;
        int c: a;
        set a: b;
        set b: c + b;
        set steps: steps + 1;
    end
end


int main()
    call fib(30);
    print 10;
    return 13;
end