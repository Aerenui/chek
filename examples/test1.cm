# ==========================================
# test | generated by AI
# ==========================================

# 1. Imports
include "libs/print_int.cm";

# 2. Global Variables & Constant Expressions
global int g_var1: 100;
global int g_var2: g_var1 * 2 + 50; # Should evaluate to 250

# 3. Void function with exact maximum arguments (6)
void print_six_chars(c1, c2, c3, c4, c5, c6)
    print c1 c2 c3 c4 c5 c6 10; # 10 is the ASCII newline character
    return; # Optional in void, but tests the parser's handling of empty returns
end

# 4. Recursion & Branching
int fibonacci(n)
    # Testing the equality operator (=)
    if n = 0 then
        return 0;
    end
    if n = 1 then
        return 1;
    end

    int t1: 0;
    int t2: 0;

    # Testing operator precedence: 'n-1' and 'n-2' inside arguments
    call fibonacci(n - 1) into t1;
    call fibonacci(n - 2) into t2;

    return t1 + t2;
end

# 5. Complex Math & Operator Precedence
int test_math(a, b, c)
    # Tests: *, /, %, +, -
    # Should automatically evaluate as: a + ((b * c) / 2) - (c % 3)
    return a + b * c / 2 - c % 3;
end

# 6. Entry Point
int main()
    # --- A. Scope Shadowing Test ---
    int g_var1: 10; # Shadows the global g_var1 (100 -> 10)

    if g_var1 = 10 then
        int g_var1: 5; # Shadows the function-level g_var1 (10 -> 5)

        # Testing the NOT EQUAL operator (!)
        if g_var1 ! 5 then
            print 69 82 82 79 82 10; # Prints "ERROR\n"
        end
    else
        print 69 82 82 79 82 10; # Prints "ERROR\n"
    end

    # --- B. Max Arguments & Print Chain Test ---
    # Prints "TEST: " -> (T=84, E=69, S=83, T=84, :=58, [space]=32)
    call print_six_chars(84, 69, 83, 84, 58, 32);

    # --- C. While Loops & Logical Operators Test ---
    int loop_counter: 0;
    int sum: 0;

    while loop_counter < 5 do
        # Testing logical OR (|)
        if loop_counter = 2 | loop_counter = 4 then
            set sum: sum + loop_counter;
        else
            # Testing logical AND (&)
            if loop_counter > 0 & loop_counter < 3 then
                set sum: sum + 1;
            end
        end
        set loop_counter: loop_counter + 1;
    end

    # --- D. Function Calls & Variable Capturing (into) ---
    int fib_result: 0;
    call fibonacci(6) into fib_result; # Fibonacci(6) = 8

    int math_result: 0;
    # 10 + (5 * 4) / 2 - (4 % 3) = 10 + 10 - 1 = 19
    call test_math(10, 5, 4) into math_result;

    # --- E. Final State Verification ---
    # Verify our math and recursion yielded the right values
    if fib_result = 8 & math_result = 19 then
        # Prints "OK" -> 79 75 10
        print 79 75 10;
    else
        # Prints "FAIL" -> 70 65 73 76 10
        print 70 65 73 76 10;
    end

    return 0;
end