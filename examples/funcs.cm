
void abc()
    int i: 97;
    while i < 97 + 26 do
        print i;
        set i: i + 1;
    end
    print 10;
end

void print_4(a,b,c,d)
    print a 32;
    print b 32;
    print c 32;
    print d 32;
end

int add(var_a, var_b)
    return var_a + var_b;
end

int main()
    int a: 1;
    print 64 10;
    call abc();
    call print_4(64, 32+32, 90+7, 100);
    print 10;
    int c: 0;
    call add(90, 7) into c;
    print c;
    print 10;

    return 0;
end



