# --- GLOBAL FRAMEWORK TRACKING COUNTERS ---
global int total_assertions: 0;
global int passed_assertions: 0;
global int failed_assertions: 0;

# --- GLOBAL STATE FOR ARCHITECTURAL TESTS ---
global int global_core_state: 500;
global int global_dependency: global_core_state * 2 - 250; # Evaluates to 750

# --- CORE INTEGRITY PRINT ENGINE ---
void print_digit_recursive(val)
    if val = 0 then
        return;
    end
    int remainder: val % 10;
    call print_digit_recursive(val / 10);
    print remainder + 48; # Integer to ASCII character conversion
end

void print_integer(val)
    if val < 0 then
        print 45; # '-' character
        set val: 0 - val;
    end
    if val = 0 then
        print 48; # '0' character
    else
        call print_digit_recursive(val);
    end
end

void run_assert(expected, actual, assertion_id)
    set total_assertions: total_assertions + 1;
    if expected = actual then
        set passed_assertions: passed_assertions + 1;
        print "[PASS] Assertion Cluster ID: ";
        call print_integer(assertion_id);
        print 10;
    else
        set failed_assertions: failed_assertions + 1;
        print "[FAIL] !!! INVALID CODE GENERATION DETECTED !!!" 10;
        print "       Cluster ID: ";
        call print_integer(assertion_id);
        print " | Expected: ";
        call print_integer(expected);
        print " | Received: ";
        call print_integer(actual);
        print 10;
    end
end

# ==============================================================================
# MODULE 1: REGISTER ALLOCATION & EXPRESSION TREE SPILLING (THE "MEGAMUNCH")
# ==============================================================================
# Forces single-pass compilers to exhaust finite x86_64 CPU scratch registers,
# testing if intermediate tree node values correctly spill and reload from stack frames.
# ==============================================================================
void stress_test_register_spilling()
    int term_a: 5;
    int term_b: 12;
    int term_c: 3;
    int term_d: 144;
    int term_e: 2;
    int term_f: 9;
    int computed_result: 0;

    # Massive calculation tree forcing deep AST parsing and register utilization
    # Standard precedence: * / % first, then + -, evaluated left to right
    set computed_result: (term_a * term_b) + (term_d / term_b) - (term_c * term_e * term_f) + (term_d % term_f) - (term_a + term_b + term_c + term_d) * term_e / 4;
    # (60) + (12) - (54) + (0) - (164) * 2 / 4
    # 72 - 54 + 0 - 328 / 4 -> 18 - 82 = -64
    call run_assert(0 - 64, computed_result, 1001);

    # Testing massive logical expression precedence evaluation heights
    # < > = ! evaluate before | &
    int logic_tree: (term_a < term_b) & (term_d > term_c) | (term_b = 99) & (term_e ! 2);
    # (1) & (1) | (0) & (0) -> 1 | 0 -> 1
    call run_assert(1, logic_tree, 1002);

    int quirk_check: 1 | 1 & 0;
    call run_assert(1, quirk_check, 1003);
end

# ==============================================================================
# MODULE 2: DEEP COMPLEX SCOPE SHADOWING MELTDOWN (THE "INCEPTION" MATRIX)
# ==============================================================================
# Spawns structural block layers deep inside loops and conditionals. Tests if
# the internal compiler symbol table tracks lexical environments cleanly when popped.
# ==============================================================================
void stress_test_scope_inception()
    int diagnostic_target: 100;
    call run_assert(100, diagnostic_target, 2001);

    if diagnostic_target = 100 then
        int diagnostic_target: 200; # Layer 1 Shadowing
        call run_assert(200, diagnostic_target, 2002);

        if diagnostic_target = 200 then
            int diagnostic_target: 300; # Layer 2 Shadowing
            call run_assert(300, diagnostic_target, 2003);

            int execution_loop: 1;
            while execution_loop = 1 do
                int diagnostic_target: 400; # Layer 3 Shadowing inside loop
                call run_assert(400, diagnostic_target, 2004);

                if 1 then
                    int diagnostic_target: 500; # Layer 4 Shadowing
                    call run_assert(500, diagnostic_target, 2005);

                    if 1 then
                        int diagnostic_target: 600; # Layer 5 Shadowing
                        call run_assert(600, diagnostic_target, 2006);

                        if 1 then
                            int diagnostic_target: 700; # Layer 6 Shadowing
                            call run_assert(700, diagnostic_target, 2007);
                        end

                        call run_assert(600, diagnostic_target, 2008); # Unwind Layer 6
                    end

                    call run_assert(500, diagnostic_target, 2009); # Unwind Layer 5
                end

                call run_assert(400, diagnostic_target, 2010); # Unwind Layer 4
                set execution_loop: 0;
            end

            call run_assert(300, diagnostic_target, 2011); # Unwind Layer 3 Loop
        end

        call run_assert(200, diagnostic_target, 2012); # Unwind Layer 2
    end

    call run_assert(100, diagnostic_target, 2013); # Unwind Layer 1 (Back to base local)
end

# ==============================================================================
# MODULE 3: LINEAR CONGRUENTIAL PSEUDO-RANDOM NUMBER ENGINE & VALIDATION MATRIX
# ==============================================================================
# Implements an algebraic deterministic LCG state math generator.
# Tests highly interactive recursive updates to variables inside iterative states.
# ==============================================================================
global int lcg_seed: 12345;

int execute_lcg_step()
    # Formula: X_{n+1} = (A * X_n + C) % M
    # Utilizing values: A = 1103515245 (scaled for 32-bit int checks), C = 12345, M = 32768
    # Let's execute realistic signed 32-bit bound calculations
    int multiplier: 13;
    int increment: 7;
    int modulus: 1000;

    set lcg_seed: (lcg_seed * multiplier + increment) % modulus;
    if lcg_seed < 0 then
        set lcg_seed: 0 - lcg_seed; # Enforce absolute positivity
    end
    return lcg_seed;
end

void run_lcg_matrix_validation()
    int loop_counter: 0;
    int current_rand: 0;
    int accumulator_sum: 0;

    while loop_counter < 10 do
        call execute_lcg_step() into current_rand;
        set accumulator_sum: accumulator_sum + current_rand;
        set loop_counter: loop_counter + 1;
    end

    # Validates deterministic consistency over 10 consecutive loops
    call run_assert(5227, accumulator_sum, 3001);
end

# ==============================================================================
# MODULE 4: THE "TINY-VM" STATE MACHINE EMULATOR
# ==============================================================================
# Simulates an instruction processing core with registers using structural code.
# Tests cascading switch-case approximations via heavily chained control paths.
# ==============================================================================
global int vm_reg_a: 0;
global int vm_reg_b: 0;
global int vm_reg_c: 0;
global int vm_pc: 0;

void run_vm_instruction(opcode, immediate_val)
    # Opcode 1: SET REG_A IMMEDIATE
    if opcode = 1 then
        set vm_reg_a: immediate_val;
    else
        # Opcode 2: SET REG_B IMMEDIATE
        if opcode = 2 then
            set vm_reg_b: immediate_val;
        else
            # Opcode 3: ADD REG_A and REG_B INTO REG_C
            if opcode = 3 then
                set vm_reg_c: vm_reg_a + vm_reg_b;
            else
                # Opcode 4: MULTIPLY REG_C BY IMMEDIATE INTO REG_C
                if opcode = 4 then
                    set vm_reg_c: vm_reg_c * immediate_val;
                else
                    # Opcode 5: DECREMENT REG_A BY 1
                    if opcode = 5 then
                        set vm_reg_a: vm_reg_a - 1;
                    else
                        # Default Error Capture State
                        set vm_pc: 0 - 1;
                    end
                end
            end
        end
    end
    set vm_pc: vm_pc + 1;
end

void test_virtual_machine_execution()
    set vm_reg_a: 0;
    set vm_reg_b: 0;
    set vm_reg_c: 0;
    set vm_pc: 0;

    # Load 15 into Reg A
    call run_vm_instruction(1, 15);
    # Load 35 into Reg B
    call run_vm_instruction(2, 35);
    # Sum them into Reg C (15 + 35 = 50)
    call run_vm_instruction(3, 0);
    # Multiply Reg C by 3 (50 * 3 = 150)
    call run_vm_instruction(4, 3);
    # Decrement Reg A (15 - 1 = 14)
    call run_vm_instruction(5, 0);

    call run_assert(14, vm_reg_a, 4001);
    call run_assert(35, vm_reg_b, 4002);
    call run_assert(150, vm_reg_c, 4003);
    call run_assert(5, vm_pc, 4004);
end

# ==============================================================================
# MODULE 5: DEEP CO-RECURSIVE AND MATHEMATICAL GRAPH ALGORITHMS
# ==============================================================================
# Validates activation frame push/pop logic, tracking whether parameter registers
# (up to full 6 limit) clear safely without stack boundary overflow.
# ==============================================================================
int compute_collatz_steps(n, current_steps)
    if n = 1 then
        return current_steps;
    end

    int internal_result: 0;
    if n % 2 = 0 then
        call compute_collatz_steps(n / 2, current_steps + 1) into internal_result;
    else
        call compute_collatz_steps(n * 3 + 1, current_steps + 1) into internal_result;
    end
    return internal_result;
end

int fully_loaded_function(arg1, arg2, arg3, arg4, arg5, arg6)
    # Validates maximum parameter consumption (6 Arguments maximum permitted)
    int step1: arg1 + arg2;
    int step2: arg3 + arg4;
    int step3: arg5 + arg6;
    return step1 * step2 - step3;
end

void run_recursion_and_boundary_checks()
    int collatz_outcome: 0;
    # Testing sequence for 7: 7->22->11->34->17->52->26->13->40->20->10->5->16->8->4->2->1 (16 Steps)
    call compute_collatz_steps(7, 0) into collatz_outcome;
    call run_assert(16, collatz_outcome, 5001);

    int boundary_outcome: 0;
    call fully_loaded_function(1, 2, 3, 4, 5, 6) into boundary_outcome;
    # (1+2) * (3+4) - (5+6) -> 3 * 7 - 11 -> 21 - 11 = 10
    call run_assert(10, boundary_outcome, 5002);
end

# ==============================================================================
# MODULE 6: COMPREHENSIVE TRUTH-TABLE LOGICAL VALIDATION MATRIX
# ==============================================================================
# Loops across logical variations to confirm truth valuations are not leaking
# native un-isolated x86 platform condition flags during operations.
# ==============================================================================
void test_logical_truth_matrix()
    int x: 0;
    int y: 0;
    int total_evaluations: 0;

    # Nested iteration producing complete condition permutations
    set x: 0;
    while x < 2 do
        set y: 0;
        while y < 2 do
            # Logical AND validation matching specification
            int and_outcome: x & y;
            if x = 1 then
                if y = 1 then
                    call run_assert(1, and_outcome, 6001);
                else
                    call run_assert(0, and_outcome, 6002);
                end
            else
                call run_assert(0, and_outcome, 6003);
            end

            # Logical OR validation matching specification
            int or_outcome: x | y;
            if x = 0 then
                if y = 0 then
                    call run_assert(0, or_outcome, 6004);
                else
                    call run_assert(1, or_outcome, 6005);
                end
            else
                call run_assert(1, or_outcome, 6006);
            end

            set total_evaluations: total_evaluations + 1;
            set y: y + 1;
        end
        set x: x + 1;
    end
    call run_assert(4, total_evaluations, 6007);
end

# ==============================================================================
# MODULE 7: GLOBAL LIFECYCLE MUTATION PIPELINE
# ==============================================================================
# Ensures changes to global cross-functional mutations do not invalidate
# offset pointers or break runtime references.
# ==============================================================================
void modify_global_states()
    set global_core_state: global_core_state + 250;
    set global_dependency: global_dependency * 2;
end

void run_global_lifecycle_tests()
    call run_assert(500, global_core_state, 7001);
    call run_assert(750, global_dependency, 7002);

    call modify_global_states();

    call run_assert(750, global_core_state, 7003);
    call run_assert(1500, global_dependency, 7004);
end

# ==============================================================================
#                          MAIN SUITE ENTRY POINT
# ==============================================================================
int main()
    print "========================================================" 10;
    print "     STARTING MULTI-MODULE COMPILER STRESS SUITE        " 10;
    print "========================================================" 10;

    print "[STAGE 1] Executing Register Spilling Tree Tests..." 10;
    call stress_test_register_spilling();

    print "[STAGE 2] Executing Deep Lexical Shadowing Inception..." 10;
    call stress_test_scope_inception();

    print "[STAGE 3] Running Algebraic Pseudo-Random LCG Loops..." 10;
    call run_lcg_matrix_validation();

    print "[STAGE 4] Processing Virtual Machine State Machine emulation..." 10;
    call test_virtual_machine_execution();

    print "[STAGE 5] Processing Collatz Recursion & 6-Param Limits..." 10;
    call run_recursion_and_boundary_checks();

    print "[STAGE 6] Generating Logical Truth Matrix Permutations..." 10;
    call test_logical_truth_matrix();

    print "[STAGE 7] Verifying Global Lifecycle State Mutations..." 10;
    call run_global_lifecycle_tests();

    print "========================================================" 10;
    print "                TESTING EXECUTION REPORT                " 10;
    print "========================================================" 10;
    print "  Total Logical Assertions Run: ";
    call print_integer(total_assertions);
    print 10;

    print "  Total Passed Assertion Checks: ";
    call print_integer(passed_assertions);
    print 10;

    print "  Total Failed Assertion Checks: ";
    call print_integer(failed_assertions);
    print 10;
    print "--------------------------------------------------------" 10;

    if failed_assertions = 0 then
        print " [SUCCESS] Binary logic behaves flawlessly across all matrices!" 10;
        return 0;
    else
        print " [FAILURE] Structural emission divergence observed inside backend." 10;
        return 1;
    end
end